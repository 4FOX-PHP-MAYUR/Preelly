{
  "watch": [
    ".",
    ".env",
    "routes",
    "models",
    "middleware",
    "config"
  ],
  "ext": "js,json,env",
  "ignore": [
    "node_modules/**",
    "uploads/**",
    "*.log",
    ".git/**"
  ],
  "exec": "node server.js",
  "env": {
    "NODE_ENV": "development"
  },
  "delay": 1000,
  "verbose": true
}

